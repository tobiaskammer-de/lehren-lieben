# Schlüssel für die Lehrkraftmentor-Funktion.
# In Vercel als "Environment Variables" des Projekts setzen, dessen
# Root Directory = "mentor-api" ist. NIEMALS echte Schlüssel committen.

# Antworten (Claude). Pflicht.
ANTHROPIC_API_KEY=sk-ant-...

# Embeddings (Suche in den Transkripten). Optional, bis die "Datenbank" gefüllt ist —
# ohne diesen Key antwortet der Mentor erstmal ohne Transkript-Suche.
OPENAI_API_KEY=sk-...

# Missbrauchsschutz: Tageslimit pro IP (20 Anfragen/Tag).
# Diese beiden Variablen werden automatisch gesetzt, wenn du in Vercel unter
# "Storage" eine Upstash-Redis-Datenbank (kostenloser Free-Tier) hinzufügst.
# Fehlen sie, läuft der Chat OHNE Limit.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
