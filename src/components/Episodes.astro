---
import { episodes, latestTwo } from '~/data/episodes';
import { asset } from '~/lib/url';

const latest = latestTwo();
const allEpisodesHref = asset('episoden/');

// Payload for the random picker script — only the fields the client needs,
// and as JSON-safe objects (no Date instances).
const randomPool = episodes.map((e) => ({
  show: e.show,
  cls: e.cls,
  ep: e.ep,
  title: e.title,
  desc: e.desc,
  dur: e.dur,
  url: e.url,
}));
---

<section id="episoden">
  <div class="container-page">
    <div
      class="s-header"
      style="display: flex; align-items: flex-end; justify-content: space-between;"
    >
      <div class="reveal">
        <span class="eyebrow">Reinhören</span>
        <h2 class="s-title">Frisch raus.</h2>
      </div>
      <a
        href={allEpisodesHref}
        class="btn btn-outline reveal"
        style="margin-bottom: 6px;"
      >
        Alle Folgen
      </a>
    </div>
    <div class="ep-grid">
      {
        latest.map((e, i) => (
          <article class={`ep-card reveal${i === 1 ? ' reveal-d1' : ''}`}>
            <div class={`ep-top-bar ${e.cls}`}></div>
            <div class="ep-show-row">
              <span class={`ep-show ${e.cls}`}>{e.show}</span>
              {e.ep && <span class="ep-num">{e.ep}</span>}
            </div>
            <h3 class="ep-title">{e.title}</h3>
            <p class="ep-desc">{e.desc}</p>
            <div class="ep-footer">
              {e.dur && <span class="ep-duration">{e.dur}</span>}
              <a
                href={e.url}
                target="_blank"
                rel="noopener"
                class={`ep-btn ${e.cls}`}
              >
                Hören
              </a>
              <a
                href={e.url}
                target="_blank"
                rel="noopener"
                class="ep-btn"
                style="border-color: rgba(42,32,24,.2); color: var(--color-muted);"
              >
                Shownotes
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <div class="random-bar reveal">
      <div>
        <div class="random-title">Nicht sicher, wo anfangen?</div>
        <div class="random-sub">
          Lass uns eine zufällige Episode für dich aussuchen.
        </div>
      </div>
      <button class="btn btn-amber" id="random-btn">
        Lass den Zufall entscheiden
      </button>
    </div>
    <div id="random-result" style="display: none;"></div>
  </div>
</section>

<script define:vars={{ episodes: randomPool }}>
  const btn = document.getElementById('random-btn');
  const out = document.getElementById('random-result');

  function render(ep) {
    const rgb = ep.cls === 'amber' ? '232,149,58' : '37,179,151';
    return `
      <article class="ep-card" style="border: 2px solid rgba(${rgb}, .25);">
        <div class="ep-top-bar ${ep.cls}"></div>
        <div class="ep-show-row">
          <span class="ep-show ${ep.cls}">${ep.show}</span>
          ${ep.ep ? `<span class="ep-num">${ep.ep}</span>` : ''}
        </div>
        <h3 class="ep-title">${ep.title}</h3>
        <p class="ep-desc">${ep.desc}</p>
        <div class="ep-footer">
          ${ep.dur ? `<span class="ep-duration">${ep.dur}</span>` : ''}
          <a href="${ep.url}" target="_blank" rel="noopener" class="ep-btn ${ep.cls}">
            Jetzt hören
          </a>
        </div>
      </article>`;
  }

  let lastIndex = -1;
  btn?.addEventListener('click', () => {
    if (!episodes || episodes.length === 0) return;
    let i = Math.floor(Math.random() * episodes.length);
    // Avoid picking the same one twice in a row
    if (episodes.length > 1 && i === lastIndex) {
      i = (i + 1) % episodes.length;
    }
    lastIndex = i;
    out.style.display = 'block';
    out.innerHTML = render(episodes[i]);
  });
</script>
