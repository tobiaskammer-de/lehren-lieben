---
import { asset } from '~/lib/url';
const year = new Date().getFullYear();
const impressum = asset('impressum');
const datenschutz = asset('datenschutz');
---

<footer>
  <div class="container-page">
    <div class="footer-grid">
      <div>
        <div class="footer-brand">
          <img
            src={asset('uploads/Transparent Logo.png')}
            alt=""
            style="height: 40px; width: auto;"
          />
          LEHREN <em>LIEBEN.</em>
        </div>
        <p class="footer-tagline">
          Podcasts für Lehrkräfte,<br />die herausragend gut sein wollen.
        </p>
        <div class="footer-social">
          <a
            href="https://www.instagram.com/lehrenlieben.punkt/"
            target="_blank"
            rel="noopener"
            class="f-soc">Instagram</a>
        </div>
      </div>
      <div>
        <div class="f-col-title">Podcasts</div>
        <div class="f-links">
          <a
            href="https://lehrkraftbesterjobderwelt.podigee.io"
            target="_blank"
            rel="noopener"
            class="f-link">Bester Job der Welt?!</a>
          <a
            href="https://deutschlandsausgezeichnetelaehrkraefte.podigee.io"
            target="_blank"
            rel="noopener"
            class="f-link">Ausgezeichnete Lehrkräfte</a>
          <a href={asset('episoden/')} class="f-link">Alle Folgen</a>
        </div>
      </div>
      <div>
        <div class="f-col-title">Mitmachen</div>
        <div class="f-links">
          <a href="#community" class="f-link">Newsletter</a>
          <a href="#gastbewerbung" class="f-link">Als Gast bewerben</a>
          <a href="#mentor" class="f-link">KI-Mentor</a>
        </div>
      </div>
      <div>
        <div class="f-col-title">Rechtliches</div>
        <div class="f-links">
          <a href={impressum} class="f-link">Impressum</a>
          <a href={datenschutz} class="f-link">Datenschutz</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="f-copy">© {year} Lehren Lieben. Alle Rechte vorbehalten.</div>
    </div>
  </div>
</footer>
