---
import { Picture } from 'astro:assets';
import { asset } from '~/lib/url';
import heroImage from '~/assets/hero.png';
---

<section id="hero">
  <div class="hero-left">
    <div class="hero-eyebrow reveal">
      <span class="eyebrow amber">Zwei Stimmen · Eine Mission</span>
    </div>
    <div class="hero-title-row reveal reveal-d1">
      <div class="hero-logo-mark" aria-hidden="true">
        <img src={asset('uploads/Transparent Logo.png')} alt="" />
      </div>
      <h1 class="hero-display">
        LEHREN<br /><em>LIEBEN.</em>
      </h1>
    </div>
    <p class="hero-sub reveal reveal-d2">
      Wir möchten Lehrkräften helfen, ihren Beruf (wieder) zu lieben — mit guten
      Gesprächen, dem Lehrkräftementor und dem geballten Wissen von
      begeisterten Lehrkräften.
    </p>
    <div class="hero-ctas reveal reveal-d2">
      <a href="#community" class="btn btn-amber">Tritt der Community bei</a>
      <a href="#podcasts" class="btn btn-soft">Zu den Podcasts</a>
    </div>
    <div class="hero-platforms reveal reveal-d3">
      <a
        href="https://open.spotify.com/show/0RBds43hBl2kGuf4LDn0pO"
        target="_blank"
        rel="noopener"
        class="plat">Spotify</a>
      <a
        href="https://podcasts.apple.com/de/podcast/lehrkraft-bester-job-der-welt/id1837156033"
        target="_blank"
        rel="noopener"
        class="plat">Apple Podcasts</a>
      <a
        href="https://www.instagram.com/lehrenlieben.punkt/"
        target="_blank"
        rel="noopener"
        class="plat">Instagram</a>
    </div>
  </div>
  <div class="hero-right">
    <Picture
      src={heroImage}
      formats={['avif', 'webp']}
      widths={[640, 960, 1280, 1600]}
      sizes="(max-width: 960px) 100vw, 50vw"
      alt="Tobias und Alexander"
      class="hero-photo"
      id="hero-img"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-photo-overlay"></div>
  </div>
</section>
