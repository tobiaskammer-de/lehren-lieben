---
import { asset } from '~/lib/url';
---

<section id="team">
  <div class="container-page">
    <div class="s-header reveal">
      <span class="eyebrow">Das Team dahinter</span>
      <h2 class="s-title">Menschen,<br />keine Marken.</h2>
    </div>

    <!-- Primary hosts -->
    <div class="team-primary">
      <article class="host-card reveal">
        <div class="host-photo-wrap">
          <img
            src={asset('uploads/Tobias.jpg')}
            alt="Tobias Kammer"
            class="host-photo"
          />
          <div class="host-photo-gradient"></div>
        </div>
        <div class="host-body">
          <div class="host-podcast">
            <span class="eyebrow amber">Bester Job der Welt?!</span>
          </div>
          <h3 class="host-name">Tobias Kammer</h3>
          <div class="host-role">
            Gymnasiallehrer · Podcaster · Methodenbuch-Autor
          </div>
          <p class="host-bio">
            Tobi unterrichtet Französisch und Pädagogik am Gymnasium und wurde
            mit dem Deutschen Lehrerpreis für innovativen Unterricht
            ausgezeichnet. Seine Lernvideos erreichen Millionen Klicks — und er
            versucht nebenbei, seinen drei Kindern zu erklären, warum Papa
            schon wieder am Schreibtisch sitzt.
          </p>
          <div class="host-links">
            <a
              href="https://smartwaerts.de"
              target="_blank"
              rel="noopener"
              class="host-link">SMARTwärts</a>
            <a href="#" class="host-link">LinkedIn</a>
            <a href="#" class="host-link">Deutscher Lehrerpreis</a>
          </div>
        </div>
      </article>

      <article class="host-card reveal reveal-d1">
        <div class="host-photo-wrap">
          <img
            src={asset('uploads/Alexander.jpg.avif')}
            alt="Alexander Böhle"
            class="host-photo"
            style="object-position: center 25%;"
          />
          <div class="host-photo-gradient"></div>
        </div>
        <div class="host-body">
          <div class="host-podcast">
            <span class="eyebrow teal">Ausgezeichnete Lehrkräfte</span>
          </div>
          <h3 class="host-name">Alexander Böhle</h3>
          <div class="host-role">
            Berufskolleg-Lehrer · Trainer · Speaker
          </div>
          <p class="host-bio">
            Alex unterrichtet am Berufskolleg und bildet Lehrkräfte in Haltung,
            Stärken stärken und Potenzialentfaltung fort. Ausschlaggebend:
            seine eigene Sinnkrise 2017. Seitdem fragt er: „Was können wir tun,
            damit Schüler und Lehrkräfte gerne in die Schule kommen?"
          </p>
          <div class="host-links">
            <a
              href="https://www.alexanderboehle.com"
              target="_blank"
              rel="noopener"
              class="host-link">alexanderboehle.com</a>
            <a href="#" class="host-link">Stärken.net</a>
            <a href="#" class="host-link">EDF</a>
            <a href="#" class="host-link">LinkedIn</a>
          </div>
        </div>
      </article>
    </div>

    <!-- Secondary team members -->
    <div class="team-secondary">
      <article class="host-card small reveal">
        <div class="host-photo-wrap">
          <div class="avatar-placeholder amber" aria-hidden="true">AL</div>
        </div>
        <div class="host-body">
          <div class="host-podcast">
            <span class="eyebrow">Team</span>
          </div>
          <h3 class="host-name">Amina Leplatoni</h3>
          <div class="host-role">Social Media & Kommunikation</div>
          <p class="host-bio">
            Amina sorgt dafür, dass die Botschaften von Lehren Lieben. da
            ankommen, wo Lehrkräfte unterwegs sind — und dass unsere Stimme
            dabei erkennbar bleibt.
          </p>
          <div class="host-links">
            <a href="#" class="host-link">LinkedIn</a>
            <a href="#" class="host-link">Instagram</a>
          </div>
        </div>
      </article>

      <article class="host-card small reveal reveal-d1">
        <div class="host-photo-wrap">
          <div class="avatar-placeholder teal" aria-hidden="true">BW</div>
        </div>
        <div class="host-body">
          <div class="host-podcast">
            <span class="eyebrow">Team</span>
          </div>
          <h3 class="host-name">Bianca Weber</h3>
          <div class="host-role">Organisation & Nachhaltigkeit</div>
          <p class="host-bio">
            Bianca hält im Hintergrund die Fäden zusammen und denkt
            nachhaltiges Projektlernen mit — damit Lehren Lieben. nicht nur
            lautstark, sondern auch verlässlich wächst.
          </p>
          <div class="host-links">
            <a href="#" class="host-link">LinkedIn</a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
